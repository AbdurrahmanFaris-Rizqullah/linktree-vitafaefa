---
interface Props {
  title: string;
  url: string;
  icon?: string;
  color?: string;
}

const { title, url, icon = '🔗', color = '#667eea' } = Astro.props;
---

<a href={url} target="_blank" rel="noopener noreferrer" class="link-card" style={`--color: ${color}`}>
  <span class="icon-wrapper">
    <i class={`icon bi ${icon}`}></i>
  </span>
  <span class="title">{title}</span>
  <span class="arrow">→</span>
</a>

<style>
  .link-card {
    display: flex;
    align-items: center;
    gap: 16px;
    padding: 18px 22px;
    border-radius: 20px;
    text-decoration: none;
    color: #ffffff;
    background: rgba(255, 255, 255, 0.08);
    border: 1px solid rgba(255, 255, 255, 0.16);
    box-shadow: 0 18px 40px rgba(0, 0, 0, 0.18);
    transition: transform 0.26s ease, background 0.26s ease, border-color 0.26s ease, box-shadow 0.26s ease;
    backdrop-filter: blur(8px);
    cursor: pointer;
  }

  .link-card:hover {
    transform: translateY(-2px);
    background: rgba(255, 255, 255, 0.14);
    border-color: rgba(255, 255, 255, 0.3);
    box-shadow: 0 26px 56px rgba(0, 0, 0, 0.22);
  }

  .icon-wrapper {
    width: 46px;
    height: 46px;
    display: grid;
    place-items: center;
    border-radius: 16px;
    background: rgba(255, 255, 255, 0.12);
    color: var(--color);
    flex-shrink: 0;
  }

  .icon {
    font-size: 1.22rem;
  }

  .title {
    flex: 1;
    font-weight: 600;
    font-size: 1rem;
    letter-spacing: 0.007em;
  }

  .arrow {
    color: var(--color);
    font-weight: 700;
    opacity: 0.82;
    transition: transform 0.26s ease, opacity 0.26s ease;
  }

  .link-card:hover .arrow {
    opacity: 1;
    transform: translateX(4px);
  }
</style>