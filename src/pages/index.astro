---
import Layout from '../layouts/Layout.astro';
import LinkCard from '../components/LinkCard.astro';
import avatarUrl from '../assets/Avatar.png?url';

interface Link {
  title: string;
  url: string;
  icon: string;
  color: string;
}

const links: Link[] = [
  {
    title: 'Lokasi Vita Faefa Kost',
    url: 'https://maps.app.goo.gl/K7iBXCBubLJ8oDh29?g_st=ic',
    icon: 'bi-geo-alt-fill',
    color: '#ffffff'
  },
  {
    title: 'Whatsaap Chat',
    url: 'https://wa.me/6285201326109',
    icon: 'bi-whatsapp',
    color: '#ffffff'
  },
  {
    title: 'Gmail For Bussiness',
    url: 'mailto:vitafaefa.official@gmail.com',
    icon: 'bi-google',
    color: '#ffffff'
  },
  {
    title: 'Web Dashboard Kost (Coming Soon)',
    url: '#',
    icon: 'bi-house-fill',
    color: '#ffffff'
  }
];
---

<Layout title="My Linktree">
  <div class="container">
    <div class="header">
      <img src={avatarUrl} alt="Profile" class="avatar" />
      <!-- <span class="tag">Kost Premium</span> -->
      <h1 class="name">Vita Faefa Kost</h1>
      <p class="bio, tag">Kost Putri Hommy, Nyaman, & Tenang di <b>Daerah Sukun - Janti</b> </p>
    </div>

    <div class="links">
      {links.map((link) => (
        <LinkCard
          title={link.title}
          url={link.url}
          icon={link.icon}
          color={link.color}
        />
      ))}
    </div>

    <footer class="footer">
      <p>© 2026 Faris. All rights reserved.</p>
    </footer>
  </div>
</Layout>

<style>
  .links {
    display: grid;
    gap: 14px;
    animation: fadeIn 0.5s ease-in;
  }

  .footer {
    margin-top: 34px;
    text-align: center;
    color: rgba(255, 255, 255, 0.72);
    font-size: 0.9rem;
  }

  .tag {
    display: inline-block;
    margin-bottom: 18px;
    padding: 8px 16px;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.14);
    color: #e6e6ff;
    font-size: 0.78rem;
    text-transform: uppercase;
    letter-spacing: 0.16em;
    border: 1px solid rgba(255, 255, 255, 0.22);
    box-shadow: inset 0 0 12px rgba(255, 255, 255, 0.08);
  }

  @keyframes fadeIn {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>